# Sasha Brain Bridge — VPS environment variables
# Copy to /etc/sasha/env on the VPS and fill in the values.
# Protect it:  chmod 600 /etc/sasha/env

# ── Ollama (local LLM) ────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Groq cloud fallback (optional but recommended) ────────────────────────────
# Free tier at https://console.groq.com — no credit card required.
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ── Security ──────────────────────────────────────────────────────────────────
# Shared secret between VPS Brain and your local Satellite.
# Generate:  python3 -c "import secrets; print(secrets.token_hex(32))"
# Set the same value on your local PC in ~/.config/jarvis/settings.env
SASHA_BRIDGE_TOKEN=CHANGE_ME_generate_with_secrets_token_hex_32

# ── Telegram bot ──────────────────────────────────────────────────────────────
# Message @BotFather on Telegram → /newbot → copy the token here.
TELEGRAM_BOT_TOKEN=

# ── Server binding ────────────────────────────────────────────────────────────
# Bind to loopback — nginx handles public TLS termination.
JARVIS_SERVER_HOST=127.0.0.1
JARVIS_SERVER_PORT=8765

# ── Memory storage ────────────────────────────────────────────────────────────
JARVIS_MEMORY_FILE=/var/lib/sasha/memory.json

# ── Optional customisation ────────────────────────────────────────────────────
WEATHER_LOCATION=
# JARVIS_SYSTEM_PROMPT=Be concise and practical. Prefer actionable responses.
